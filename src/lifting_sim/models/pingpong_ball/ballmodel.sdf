<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="pingpong_ball">
    <pose>0 0 1.0 0 0 0</pose>
    <link name="link">
      <inertial>
        <mass>0.0027</mass> <inertia>
          <ixx>0.0000002</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.0000002</iyy><iyz>0</iyz>
          <izz>0.0000002</izz>
        </inertia>
      </inertial>
      <visual name="visual">
        <geometry>
          <sphere><radius>0.02</radius></sphere>
        </geometry>
