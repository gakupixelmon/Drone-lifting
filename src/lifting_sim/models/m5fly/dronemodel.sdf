<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="m5fly">
    <pose>0 0 0.3 0 0 0</pose>

    <link name="base_link">
      <inertial>
        <mass>0.035</mass>
        <inertia>
          <ixx>0.00003</ixx><ixy>0</ixy><ixz>0</ixz>
          <iyy>0.00003</iyy><iyz>0</iyz>
          <izz>0.00006</izz>
        </inertia>
      </inertial>

      <visual name="body_visual">
        <geometry>
          <box><size>0.07 0.07 0.05</size></box>
        </geometry>
        <!--
          Bug5 修正: OGRE2 レンダリング対応マテリアル
          emissive 0.0 0.0 0.5 で自発光 → 照明条件によらず常に安定した青
          ambient を高めに設定 → 影側でも青色を維持
        -->
        <material>
          <ambient>0.0 0.0 0.8 1</ambient>
          <diffuse>0.0 0.0 1.0 1</diffuse>
          <specular>0.0 0.0 0.1 1</specular>
          <emissive>0.0 0.0 0.5 1</emissive>
        </material>
      </visual>

      <collision name="collision">
        <geometry>
          <box><size>0.07 0.07 0.02</size></box>
        </geometry>
        <surface>
          <bounce>
            <restitution_coefficient>1.0</restitution_coefficient>
            <threshold>0</threshold>
          </bounce>
          <contact>
            <ode><max_vel>100</max_vel><min_depth>0.001</min_depth></ode>
          </contact>
        </surface>
      </collision>

      <collision name="top_guard_collision">
        <pose>0 0 0.035 0 0 0</pose>
        <geometry>
          <box><size>0.09 0.09 0.002</size></box>
        </geometry>
        <surface>
          <friction>
            <ode><mu>0.0</mu><mu2>0.0</mu2></ode>
          </friction>
          <bounce>
            <restitution_coefficient>0.9</restitution_coefficient>
            <threshold>0.01</threshold>
          </bounce>
          <contact>
            <ode><max_vel>100</max_vel><min_depth>0.001</min_depth></ode>
          </contact>
        </surface>
      </collision>
    </link>

    <link name="rotor_0">
      <pose>0.025 -0.025 0.02 0 0 0</pose>
      <inertial><mass>0.001</mass>
        <inertia><ixx>0.000001</ixx><iyy>0.000001</iyy><izz>0.000001</izz></inertia>
      </inertial>
      <visual name="rotor_0_visual">
        <geometry><cylinder><radius>0.02</radius><length>0.002</length></cylinder></geometry>
        <material><diffuse>0.2 0.2 0.2 0.3</diffuse></material>
      </visual>
      <collision name="rotor_0_collision">
        <geometry><cylinder><radius>0.02</radius><length>0.002</length></cylinder></geometry>
      </collision>
    </link>
    <joint name="rotor_0_joint" type="revolute">
      <parent>base_link</parent><child>rotor_0</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <link name="rotor_1">
      <pose>-0.025 -0.025 0.02 0 0 0</pose>
      <inertial><mass>0.001</mass>
        <inertia><ixx>0.000001</ixx><iyy>0.000001</iyy><izz>0.000001</izz></inertia>
      </inertial>
      <visual name="rotor_1_visual">
        <geometry><cylinder><radius>0.02</radius><length>0.002</length></cylinder></geometry>
        <material><diffuse>0.2 0.2 0.2 0.3</diffuse></material>
      </visual>
      <collision name="rotor_1_collision">
        <geometry><cylinder><radius>0.02</radius><length>0.002</length></cylinder></geometry>
      </collision>
    </link>
    <joint name="rotor_1_joint" type="revolute">
      <parent>base_link</parent><child>rotor_1</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <link name="rotor_2">
      <pose>0.025 0.025 0.02 0 0 0</pose>
      <inertial><mass>0.001</mass>
        <inertia><ixx>0.000001</ixx><iyy>0.000001</iyy><izz>0.000001</izz></inertia>
      </inertial>
      <visual name="rotor_2_visual">
        <geometry><cylinder><radius>0.02</radius><length>0.002</length></cylinder></geometry>
        <material><diffuse>0.2 0.2 0.2 0.3</diffuse></material>
      </visual>
      <collision name="rotor_2_collision">
        <geometry><cylinder><radius>0.02</radius><length>0.002</length></cylinder></geometry>
      </collision>
    </link>
    <joint name="rotor_2_joint" type="revolute">
      <parent>base_link</parent><child>rotor_2</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <link name="rotor_3">
      <pose>-0.025 0.025 0.02 0 0 0</pose>
      <inertial><mass>0.001</mass>
        <inertia><ixx>0.000001</ixx><iyy>0.000001</iyy><izz>0.000001</izz></inertia>
      </inertial>
      <visual name="rotor_3_visual">
        <geometry><cylinder><radius>0.02</radius><length>0.002</length></cylinder></geometry>
        <material><diffuse>0.2 0.2 0.2 0.3</diffuse></material>
      </visual>
      <collision name="rotor_3_collision">
        <geometry><cylinder><radius>0.02</radius><length>0.002</length></cylinder></geometry>
      </collision>
    </link>
    <joint name="rotor_3_joint" type="revolute">
      <parent>base_link</parent><child>rotor_3</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <plugin filename="ignition-gazebo-multicopter-control-system"
            name="ignition::gazebo::systems::MulticopterVelocityControl">
      <robotNamespace>m5fly</robotNamespace>
      <commandSubTopic>cmd_vel</commandSubTopic>
      <comLinkName>base_link</comLinkName>
      <!--
        修正: velocityGain 5.0 → 15.0
        旧 τ=2.0s → 上昇し続ける根本原因
        新 τ=0.067s (外側ループの約11倍速い) → カスケード安定
      -->
      <velocityGain>15.0 15.0 15.0</velocityGain>
      <attitudeGain>0.2 0.2 0.2</attitudeGain>
      <angularRateGain>0.05 0.05 0.05</angularRateGain>
      <maximumLinearAcceleration>20 20 20</maximumLinearAcceleration>
      <rotorConfiguration>
        <rotor>
          <jointName>rotor_0_joint</jointName>
          <forceConstant>4.0e-07</forceConstant><momentConstant>1e-7</momentConstant>
          <direction>-1</direction>
        </rotor>
        <rotor>
          <jointName>rotor_1_joint</jointName>
          <forceConstant>4.0e-07</forceConstant><momentConstant>1e-7</momentConstant>
          <direction>1</direction>
        </rotor>
        <rotor>
          <jointName>rotor_2_joint</jointName>
          <forceConstant>4.0e-07</forceConstant><momentConstant>1e-7</momentConstant>
          <direction>1</direction>
        </rotor>
        <rotor>
          <jointName>rotor_3_joint</jointName>
          <forceConstant>4.0e-07</forceConstant><momentConstant>1e-7</momentConstant>
          <direction>-1</direction>
        </rotor>
      </rotorConfiguration>
    </plugin>

    <plugin filename="ignition-gazebo-multicopter-motor-model-system"
            name="ignition::gazebo::systems::MulticopterMotorModel">
      <robotNamespace>m5fly</robotNamespace>
      <jointName>rotor_0_joint</jointName><linkName>rotor_0</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp><timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>800.0</maxRotVelocity>
      <motorConstant>4.0e-07</motorConstant><momentConstant>1e-7</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>0</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-6</rollingMomentCoefficient>
      <motorSpeedPubTopic>motor_speed/0</motorSpeedPubTopic>
    </plugin>

    <plugin filename="ignition-gazebo-multicopter-motor-model-system"
            name="ignition::gazebo::systems::MulticopterMotorModel">
      <robotNamespace>m5fly</robotNamespace>
      <jointName>rotor_1_joint</jointName><linkName>rotor_1</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp><timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>800.0</maxRotVelocity>
      <motorConstant>4.0e-07</motorConstant><momentConstant>1e-7</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>1</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-6</rollingMomentCoefficient>
      <motorSpeedPubTopic>motor_speed/1</motorSpeedPubTopic>
    </plugin>

    <plugin filename="ignition-gazebo-multicopter-motor-model-system"
            name="ignition::gazebo::systems::MulticopterMotorModel">
      <robotNamespace>m5fly</robotNamespace>
      <jointName>rotor_2_joint</jointName><linkName>rotor_2</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp><timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>800.0</maxRotVelocity>
      <motorConstant>4.0e-07</motorConstant><momentConstant>1e-7</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>2</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-6</rollingMomentCoefficient>
      <motorSpeedPubTopic>motor_speed/2</motorSpeedPubTopic>
    </plugin>

    <plugin filename="ignition-gazebo-multicopter-motor-model-system"
            name="ignition::gazebo::systems::MulticopterMotorModel">
      <robotNamespace>m5fly</robotNamespace>
      <jointName>rotor_3_joint</jointName><linkName>rotor_3</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp><timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>800.0</maxRotVelocity>
      <motorConstant>4.0e-07</motorConstant><momentConstant>1e-7</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>3</motorNumber>
      <rotorDragCoefficient>8.06428e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>1e-6</rollingMomentCoefficient>
      <motorSpeedPubTopic>motor_speed/3</motorSpeedPubTopic>
    </plugin>
  </model>
</sdf>
